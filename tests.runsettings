<?xml version="1.0" encoding="utf-8"?>
<RunSettings>
  <MSTest>
    <Parallelize>
      <Workers>4</Workers>
      <Scope>ClassLevel</Scope>
    </Parallelize>
  </MSTest>
  <DataCollectionRunSettings>
    <DataCollectors>
      <DataCollector friendlyName="XPlat Code Coverage">
        <Configuration>
          <Format>opencover</Format>
          <Exclude>[*.Tests]*,[*]*.Models.*,[*]*.DTOs.*,[*]*.Migrations.*,[SmartSure.Contracts]*</Exclude>
          <ExcludeByFile>**/Program.cs,**/Controllers/**,**/Repositories/**,**/Data/**,**/Consumers/**,**/Migrations/**</ExcludeByFile>
        </Configuration>
      </DataCollector>
    </DataCollectors>
  </DataCollectionRunSettings>
  <TestRunParameters>
    <Parameter name="Environment" value="Test" />
  </TestRunParameters>
</RunSettings>
